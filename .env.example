# =====================================================================
# Green Lab Support — environment variables (DO NOT commit real values)
# Copy this file to .env and fill in. Never commit .env.
# =====================================================================

# ---------- Database ----------
DATABASE_URL=postgresql+asyncpg://greenlab:greenlab@localhost:5432/greenlab
# Enable pgvector extension on Neon/Supabase; locally: docker compose handles it.

# ---------- Redis (Upstash) ----------
REDIS_URL=redis://localhost:6379/0

# ---------- LLM providers ----------
# Anthropic with BAA + zero-retention for HIPAA posture.
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_BRAIN_MODEL=claude-sonnet-4-5
ANTHROPIC_ROUTER_MODEL=claude-haiku-4-5
# Critical HIPAA flag — keep this true in production.
ANTHROPIC_ZERO_RETENTION=true

# OpenAI as fallback only.
OPENAI_API_KEY=sk-...
OPENAI_FALLBACK_MODEL=gpt-4.1-mini

# Embeddings + rerank
VOYAGE_API_KEY=pa-...
COHERE_API_KEY=co-...

# ---------- Observability ----------
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2-pt_...
LANGCHAIN_PROJECT=green-lab-support
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ---------- Channels ----------
POSTMARK_SERVER_TOKEN=
POSTMARK_WEBHOOK_SECRET=
META_WHATSAPP_TOKEN=
META_WHATSAPP_PHONE_ID=
VAPI_API_KEY=
VAPI_ASSISTANT_ID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# ---------- Tool integrations ----------
ZENDESK_SUBDOMAIN=
ZENDESK_EMAIL=
ZENDESK_API_TOKEN=
HUBSPOT_ACCESS_TOKEN=
CALCOM_API_KEY=
CALCOM_USERNAME=

# ---------- Storage ----------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=green-lab-reports

# ---------- Auth ----------
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# ---------- Application ----------
APP_ENV=development
APP_LOG_LEVEL=INFO
APP_PII_REDACTION=true
APP_AUDIT_RETENTION_DAYS=2555  # 7 years for HIPAA
APP_REQUIRE_HUMAN_TIERS=tier3,tier4

# Vector store collection names
DOCS_COLLECTION=green_lab_docs
CHECKPOINT_COLLECTION=green_lab_checkpoints
